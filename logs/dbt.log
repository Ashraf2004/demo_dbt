[0m05:24:34.498699 [debug] [Thread-2 (]: On model.demo_dbt.sales_data: /* {"app": "dbt", "dbt_version": "1.9.4", "profile_name": "demo_dbt", "target_name": "dev", "node_id": "model.demo_dbt.sales_data"} */
create or replace transient table POC_DBT_PROJECT.UTILS_staging.sales_data
         as
        (

with raw_sales as (
    select 1 as sale_id, 'john doe' as customer_name, 15000 as amount_cents, '2024-01-15'::date as sale_date
    union all
    select 2, 'jane smith', 25000, '2024-02-20'::date
    union all
    select 3, 'bob johnson', 35000, '2024-03-10'::date
    union all
    select 4, null, 10000, '2024-04-05'::date
)

select
    sale_id,
    
    trim(upper(customer_name))
 as customer_name_clean,
    amount_cents,
    
    round(amount_cents / 100.0, 2)
 as amount_dollars,
    sale_date,
    
    case 
        when month(sale_date) >= 4
        then year(sale_date)
        else year(sale_date) - 1
    end
 as fiscal_year,
    
    
        current_timestamp()
    
 as loaded_at
from raw_sales
where customer_name is not null
        );
